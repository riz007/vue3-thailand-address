{
  "name": "vue3-thailand-address",
  "version": "1.0.8",
  "description": "A Vue 3 component for selecting Thai addresses with province, district, and sub-district options.",
  "keywords": [
    "vue3",
    "thailand",
    "address",
    "component",
    "province",
    "district",
    "sub-district"
  ],
  "author": "riz007",
  "repository": {
    "type": "git",
    "url": "https://github.com/riz007/vue3-thailand-address"
  },
  "homepage": "https://github.com/riz007/vue3-thailand-address",
  "bugs": {
    "url": "https://github.com/riz007/vue3-thailand-address/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./data": {
      "types": "./dist/data.d.ts",
      "import": "./dist/data.mjs",
      "require": "./dist/data.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:demo": "vite --config vite.demo.config.mts",
    "build:demo": "vite build --config vite.demo.config.mts",
    "deploy:demo": "yarn build:demo && gh-pages -d demo/dist",
    "build": "vite build && yarn build:types",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "prepublishOnly": "yarn build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "optionalDependencies": {
    "@riz007/thai-address-data": "^0.1.4"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "gh-pages": "^6.1.1",
    "@types/node": "^25.0.10",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^24.1.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^2.1.0",
    "vue": "^3.5.27",
    "vue-tsc": "^3.2.3"
  }
}
